//@version=5
indicator(title="资金费率套利探测器 | Funding Rate Arbitrage Scout", 
         shorttitle="FRA Scout", 
         overlay=false, 
         timeframe="", 
         timeframe_gaps=false)

// ============================================================
// 资金费率套利探测器 — Funding Rate Arbitrage Scout
// 
// 用途：监控永续合约资金费率，识别正费率做空/负费率做多机会
// 适用平台：币安、Bybit、OKX、Hyperliquid 等 USDT 永续合约
// 作者：一人公司交易团队
// 版本：1.0
// ============================================================

// ─── 输入参数 ──────────────────────────────────────
show_funding_rate     = input.bool(true,    "显示资金费率")
show_funding_ma       = input.bool(true,    "显示费率移动平均线")
funding_ma_length     = input.int(8,        "费率均线周期")
arbitrage_threshold   = input.float(0.01,   "套利阈值 (%)", step=0.005)
show_signal_alerts    = input.bool(true,    "显示信号标签")
show_background       = input.bool(true,    "显示背景色")

// ─── 获取资金费率数据 ──────────────────────────────
// 注意：TradingView 原生支持 funding_rate，可直接调用
funding_rate = request.security(syminfo.tickerid, "1D", 
                                fundings_rate(funding_field="fundingRate")) * 100

// 部分交易对可能有 8h 费率，TradingView 可能以 1d 提供
// 备选方案：手动计算 8h 费率
funding_8h = request.security(syminfo.tickerid, timeframe.period,
                              fundings_rate(funding_field="fundingRate")) * 100

// ─── 计算指标 ──────────────────────────────────────
funding_ma = ta.sma(funding_rate, funding_ma_length)

// 判断套利方向
is_positive_arb = funding_rate > arbitrage_threshold   // 正费率 → 做空有收益
is_negative_arb = funding_rate < -arbitrage_threshold  // 负费率 → 做多有收益
is_high_arb     = math.abs(funding_rate) > arbitrage_threshold * 2  // 高套利机会

// 均线穿越信号
cross_above_ma = ta.crossunder(funding_rate, funding_ma)  // 费率跌破均线 → 可能转负
cross_below_ma = ta.crossover(funding_rate, funding_ma)   // 费率突破均线 → 可能转正

// ─── 绘制 ──────────────────────────────────────────
hline(0, "零线", color=color.gray, linestyle=hline.style_dashed)
hline(arbitrage_threshold, "阈值上", color=color.new(color.green, 70))
hline(-arbitrage_threshold, "阈值下", color=color.new(color.red, 70))

// 资金费率柱状图
bar_color = funding_rate > 0 ? color.green : color.red
plot(funding_rate, "资金费率 (%)", color=bar_color, style=plot.style_histogram, 
     linewidth=2, trackprice=true)

// 移动平均线
plot(funding_ma, "费率 MA", color=color.blue, linewidth=1)

// ─── 信号标签 ──────────────────────────────────────
if show_signal_alerts
    // 做空信号：正费率超过阈值
    if is_positive_arb
        label.new(bar_index, funding_rate, 
                  text="做空\n费率 " + str.tostring(funding_rate, "#.##%"), 
                  style=label.style_label_down, color=color.new(color.red, 40),
                  textcolor=color.white, size=size.small)
    
    // 做多信号：负费率低于负阈值
    if is_negative_arb
        label.new(bar_index, funding_rate, 
                  text="做多\n费率 " + str.tostring(funding_rate, "#.##%"), 
                  style=label.style_label_up, color=color.new(color.green, 40),
                  textcolor=color.white, size=size.small)
    
    // 高套利机会
    if is_high_arb
        label.new(bar_index, funding_rate, 
                  text="高套利!\n" + str.tostring(math.abs(funding_rate), "#.##%"), 
                  style=label.style_label_center, color=color.new(color.purple, 50),
                  textcolor=color.white, size=size.small)

// ─── 背景色 ──────────────────────────────────────────
if show_background
    bgcolor(is_positive_arb ? color.new(color.red, 90) : na)
    bgcolor(is_negative_arb ? color.new(color.green, 90) : na)
    bgcolor(is_high_arb ? color.new(color.purple, 85) : na)

// ─── 数据表 ──────────────────────────────────────────
if barstate.islast
    var table_info = table.new(position.top_right, 4, 4, 
                               border_width=1, border_color=color.gray,
                               frame_width=1, frame_color=color.gray)
    
    header_color = color.new(color.blue, 60)
    cell(tabela_id=table_info, column=0, row=0, text="指标", 
         bgcolor=header_color, textcolor=color.white)
    cell(tabela_id=table_info, column=1, row=0, text="值", 
         bgcolor=header_color, textcolor=color.white)
    cell(tabela_id=table_info, column=2, row=0, text="状态", 
         bgcolor=header_color, textcolor=color.white)
    cell(tabela_id=table_info, column=3, row=0, text="建议", 
         bgcolor=header_color, textcolor=color.white)
    
    cell(tabela_id=table_info, column=0, row=1, text="当前费率")
    cell(tabela_id=table_info, column=1, row=1, text=str.tostring(funding_rate, "#.####%"))
    cell(tabela_id=table_info, column=2, row=1, text=funding_rate > 0 ? "正费率" : "负费率",
         textcolor=funding_rate > 0 ? color.red : color.green)
    
    if is_positive_arb
        cell(tabela_id=table_info, column=3, row=1, text="考虑做空", textcolor=color.red)
    else if is_negative_arb
        cell(tabela_id=table_info, column=3, row=1, text="考虑做多", textcolor=color.green)
    else
        cell(tabela_id=table_info, column=3, row=1, text="观望", textcolor=color.gray)
    
    cell(tabela_id=table_info, column=0, row=2, text="费率 MA")
    cell(tabela_id=table_info, column=1, row=2, text=str.tostring(funding_ma, "#.####%"))
    cell(tabela_id=table_info, column=2, row=2, text=funding_rate > funding_ma ? "上穿" : "下破")
    
    cell(tabela_id=table_info, column=0, row=3, text="套利阈值")
    cell(tabela_id=table_info, column=1, row=3, text=str.tostring(arbitrage_threshold, "#.##%"))
    cell(tabela_id=table_info, column=2, row=3, text=is_high_arb ? "高套利区" : "正常区")
    cell(tabela_id=table_info, column=3, row=3, text=is_high_arb ? "⚠️ 注意" : "")

// ─── 告警条件 ──────────────────────────────────────────
alertcondition(is_positive_arb, title="正费率报警", message="正费率：{{ticker}} 费率 {{plot(\"资金费率 (%)\")}}%")
alertcondition(is_negative_arb, title="负费率报警", message="负费率：{{ticker}} 费率 {{plot(\"资金费率 (%)\")}}%")
alertcondition(is_high_arb, title="高套利机会", message="高套利：{{ticker}} 费率 {{plot(\"资金费率 (%)\")}}%")
